{
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "autoprefixer": "^10.4.21",
    "concurrently": "^8.2.2",
    "nodemon": "^3.1.9",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "prettier-plugin-jinja-template": "^1.5.0",
    "tailwindcss": "^3.4.17"
  },
  "scripts": {
    "watch:tailwind": "tailwindcss -i ./src/index.css -o ./dist/index.css --watch",
    "watch:html": "nodemon --watch src --watch .env -e '*' --exec \"python src/build.py --output dist\"",
    "flask-dev": "python -m flask --app src/dev-server.py --debug run --port 8000",
    "dev": "concurrently \"npm run watch:html\" \"npm run watch:tailwind\" \"npm run flask-dev\"",
    "build": "powershell -ExecutionPolicy Bypass -File ./build.ps1",
    "preview": "npx serve dist/"
  }
}
